{
  "fields": [
    {
      "component": "container",
      "label": "media",
      "name": "media",
      "collapsible": true,
      "condition": {
        "===": [ { "var": "layoutStyle" }, "media" ]
      },
      "fields": [
        {
          "component": "select",
          "label": "media type",
          "name": "mediaType",
          "valueType": "string",
          "options": [
            { "name": "image", "value": "image" },
            { "name": "video", "value": "video" }
          ]
        },
        {
          "component": "text",
          "label": "media container ratio (DTM)",
          "name": "mediaContainerRatio",
          "valueType": "string",
          "description": "(Width-to-height ratio value) (1:X)"
        },
        {
          "component": "text",
          "label": "image Alt text",
          "name": "mediaImageAltText",
          "valueType": "string",
          "condition": {
            "===": [ { "var": "mediaType" }, "image" ]
          }
        },
        {
          "component": "boolean",
          "label": "video auto play(on / off)",
          "name": "mediaVideoAutoPlay",
          "valueType": "boolean",
          "condition": {
            "===": [
              {
                "var": "mediaType"
              },
              "video"
            ]
          }
        },
        {
          "component": "boolean",
          "label": "loop(on / off)",
          "name": "mediaVideoloop",
          "valueType": "boolean",
          "condition": {
            "===": [
              {
                "var": "mediaType"
              },
              "video"
            ]
          }
        },
        {
          "component": "boolean",
          "label": "pause and play btn(show / hide)",
          "name": "mediaVideoPauseAndPlayBtn",
          "valueType": "boolean",
          "condition": {
            "===": [
              {
                "var": "mediaType"
              },
              "video"
            ]
          }
        },
        {
          "component": "select",
          "label": "pause and play btn position",
          "name": "mediaVideoPauseAndPlayBtnPosition",
          "valueType": "string",
          "condition": {
            "===": [
              {
                "var": "mediaType"
              },
              "video"
            ]
          },
          "options": [
            {
              "name": "TL",
              "value": "top-left"
            },
            {
              "name": "TR",
              "value": "top-right"
            },
            {
              "name": "BL",
              "value": "bottom-left"
            },
            {
              "name": "BR",
              "value": "bottom-right"
            }
          ]
        },
        {
          "component": "boolean",
          "label": "replay btn(yes / no)",
          "name": "mediaVideoReplayBtn",
          "valueType": "boolean",
          "condition": {
            "===": [
              {
                "var": "mediaType"
              },
              "video"
            ]
          }
        },
        {
          "component": "select",
          "label": "btn theme",
          "name": "mediaVideoBtnTheme",
          "valueType": "string",
          "condition": {
            "===": [
              {
                "var": "mediaType"
              },
              "video"
            ]
          },
          "options": [
            {
              "name": "light",
              "value": "light"
            },
            {
              "name": "dark",
              "value": "dark"
            }
          ]
        }
      ]
    }
  ]
}
