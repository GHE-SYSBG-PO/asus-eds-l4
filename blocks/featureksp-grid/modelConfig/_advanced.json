{
  "fields": [
    {
      "component": "tab",
      "label": "Advanced",
      "name": "Advanced"
    },
    {
      "...": "./_text-style.json#/fields"
    },
    {
      "component": "container",
      "label": "item",
      "name": "item",
      "collapsible": true,
      "condition": {
        "===": [ { "var": "layoutStyle" }, "media" ]
      },
      "fields": [
        {
          "component": "select",
          "label": "img vertical alignment",
          "name": "itemImgVerticalAlignment",
          "valueType": "string",
          "options": [
            { "name": "top", "value": "top" },
            { "name": "bottom", "value": "bottom" },
            { "name": "center", "value": "center" }
          ]
        },
        {
          "component": "text",
          "label": "text width (D)",
          "name": "itemTextWidthD",
          "valueType": "string",
          "condition": {
            "in": [
              {
                "var": "layoutVariantD"
              },
              [
                "left",
                "right",
                "topLeft",
                "topRight",
                "bottomLeft",
                "bottomRight"
              ]
            ]
          }
        },
        {
          "component": "text",
          "label": "text width (T)",
          "name": "itemTextWidthT",
          "valueType": "string",
          "condition": {
            "in": [
              {
                "var": "layoutVariantT"
              },
              [
                "left",
                "right",
                "topLeft",
                "topRight",
                "bottomLeft",
                "bottomRight"
              ]
            ]
          }
        },
        {
          "component": "text",
          "label": "text width (M)",
          "name": "itemTextWidthM",
          "valueType": "string",
          "condition": {
            "in": [
              {
                "var": "layoutVariantM"
              },
              [
                "left",
                "right",
                "topLeft",
                "topRight",
                "bottomLeft",
                "bottomRight"
              ]
            ]
          }
        }
      ]
    },
    {
      "component": "container",
      "label": "anchor style",
      "name": "advancedAnchorStyle",
      "collapsible": true,
      "condition": {
        "===": [ { "var": "anchorStyle" }, "svg" ]
      },
      "fields": [
        {
          "component": "text",
          "label": "border width default",
          "name": "borderWidthDefault",
          "valueType": "string"
        },
        {
          "component": "text",
          "label": "border width hover",
          "name": "borderWidthHover",
          "valueType": "string"
        },
        {
          "component": "text",
          "label": "border width press",
          "name": "borderWidthPress",
          "valueType": "string"
        },
        {
          "component": "text",
          "label": "border color default",
          "name": "borderColorDefault",
          "valueType": "string"
        },
        {
          "component": "text",
          "label": "border color hover",
          "name": "borderColorHover",
          "valueType": "string"
        },
        {
          "component": "text",
          "label": "border color press",
          "name": "borderColorPress",
          "valueType": "string"
        }
      ]
    }
  ]
}
