{
  "fields": [
    {
      "component": "tab",
      "label": "tab style",
      "name": "tabStyleTab"
    },
    {
      "component": "select",
      "label": "tab style",
      "name": "tabStyle",
      "valueType": "string",
      "options": [
        { "name": "tab style 1 - Underlined_1", "value": "1" },
        { "name": "tab style 2 - Pill", "value": "2" },
        { "name": "tab style 3 -Underlined_2", "value": "3" },
        { "name": "tab style 4 - Gaming_1", "value": "4" }
      ]
    },
    {
      "component": "boolean",
      "label": "show icon (yes/no)",
      "name": "showIcon",
      "valueType": "boolean",
      "condition": {
        "in": [{ "var": "tabStyle" }, ["1", "2", "3"]]
      }
    },

    {
      "component": "container",
      "label": "tab theme",
      "name": "tabTheme",
      "collapsible": true,
      "fields": [
        {
          "component": "text",
          "label": "selected color",
          "name": "tabSelectedColor",
          "valueType": "string",
          "description": "Hex without #, e.g. 0062cd"
        },

        {
          "component": "text",
          "label": "default color (style 1, 3, 4 only)",
          "name": "tabDefaultColor",
          "valueType": "string",
          "description": "Hex without #",
          "condition": {
            "in": [{ "var": "tabStyle" }, ["1", "3", "4"]]
          }
        },
        {
          "component": "text",
          "label": "line width (style 1, 3 only)",
          "name": "tabLineWidth",
          "valueType": "string",
          "description": "Number only, unit px, e.g. 2",
          "condition": {
            "in": [{ "var": "tabStyle" }, ["1", "3"]]
          }
        },
        {
          "component": "select",
          "label": "line endpoints (style 1, 3 only)",
          "name": "tabLineEndpoints",
          "valueType": "string",
          "condition": {
            "in": [{ "var": "tabStyle" }, ["1", "3"]]
          },
          "options": [
            { "name": "round", "value": "round" },
            { "name": "square", "value": "square" }
          ]
        },
        {
          "component": "text",
          "label": "corner decoration color (style 4 only)",
          "name": "tabCornerDecorationColor",
          "valueType": "string",
          "description": "Hex without #",
          "condition": {
            "===": [{ "var": "tabStyle" }, "4"]
          }
        },
        {
          "component": "container",
          "label": "tab radius (style 2 only)",
          "name": "tabRadiusGroup",
          "condition": {
            "===": [{ "var": "tabStyle" }, "2"]
          },
          "fields": [
            {
              "component": "text",
              "label": "radius TL",
              "name": "tabRadiusTl",
              "valueType": "string"
            },
            {
              "component": "text",
              "label": "radius TR",
              "name": "tabRadiusTr",
              "valueType": "string"
            },
            {
              "component": "text",
              "label": "radius BR",
              "name": "tabRadiusBr",
              "valueType": "string"
            },
            {
              "component": "text",
              "label": "radius BL",
              "name": "tabRadiusBl",
              "valueType": "string"
            }
          ]
        }
      ]
    },

