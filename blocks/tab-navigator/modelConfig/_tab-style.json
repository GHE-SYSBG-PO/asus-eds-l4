{
  "fields": [
    {
      "component": "tab",
      "label": "theme tab",
      "name": "themeTab"
    },
    {
      "component": "text",
      "label": "selected color",
      "name": "tabSelectedColor",
      "valueType": "string",
      "description": "Hex without #, e.g. 0062cd"
    },
    {
      "component": "text",
      "label": "default color (style 1, 3, 4 only)",
      "name": "tabDefaultColor",
      "valueType": "string",
      "description": "Hex without #",
      "condition": {
        "in": [{ "var": "tabStyle" }, ["1", "3", "4"]]
      }
    },
    {
      "component": "text",
      "label": "line width (style 1, 3 only)",
      "name": "tabLineWidth",
      "valueType": "string",
      "description": "Number only, unit px, e.g. 2",
      "condition": {
        "in": [{ "var": "tabStyle" }, ["1", "3"]]
      }
    },
    {
      "component": "select",
      "label": "line endpoints (style 1, 3 only)",
      "name": "tabLineEndpoints",
      "valueType": "string",
      "condition": {
        "in": [{ "var": "tabStyle" }, ["1", "3"]]
      },
      "options": [
        { "name": "round", "value": "round" },
        { "name": "square", "value": "square" }
      ]
    },
    {
      "component": "text",
      "label": "corner decoration color (style 4 only)",
      "name": "tabCornerDecorationColor",
      "valueType": "string",
      "description": "Hex without #",
      "condition": {
        "===": [{ "var": "tabStyle" }, "4"]
      }
    },
    {
      "component": "text",
      "label": "radius TL (style 2 only)",
      "name": "tabRadiusTl",
      "valueType": "string",
      "condition": {
        "===": [{ "var": "tabStyle" }, "2"]
      }
    },
    {
      "component": "text",
      "label": "radius TR (style 2 only)",
      "name": "tabRadiusTr",
      "valueType": "string",
      "condition": {
        "===": [{ "var": "tabStyle" }, "2"]
      }
    },
    {
      "component": "text",
      "label": "radius BR (style 2 only)",
      "name": "tabRadiusBr",
      "valueType": "string",
      "condition": {
        "===": [{ "var": "tabStyle" }, "2"]
      }
    },
    {
      "component": "text",
      "label": "radius BL (style 2 only)",
      "name": "tabRadiusBl",
      "valueType": "string",
      "condition": {
        "===": [{ "var": "tabStyle" }, "2"]
      }
    }
  ]
}
