            { "name": "5", "value": "5" },
            { "name": "6", "value": "6" }
          ],
          "condition": {
            "and": [
              { "===": [{ "var": "categoryIcon" }, "yes"] },
              { "===": [{ "var": "categoryIconNum" }, "1"] }
