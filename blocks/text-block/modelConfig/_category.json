    {
      "component": "select",
      "label": "category icon",
      "name": "categoryIcon",
      "valueType": "string",
      "options": [
        { "name": "Yes", "value": "yes" },
        { "name": "No", "value": "no" }
      ]
    },
    {
      "component": "select",
      "label": "category icon num",
      "name": "categoryIconNum",
      "valueType": "string",
      "options": [
        { "name": "1", "value": "1" },
        { "name": "2", "value": "2" }
      ],
      "condition": {
        "and": [
          { "===": [{ "var": "categoryIcon" }, "yes"] }
        ]
      }
    },
