{
  "definitions": [
    {
      "title": "Tab Item",
      "id": "tab-navigator-item",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Tab Navigator Item",
              "model": "tab-navigator-item"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "tab-navigator-item",
      "fields": [
        {
          "component": "select",
          "label": "2nd layer tab (layout 4 only)",
          "name": "secondLayerTab",
          "valueType": "string",
          "options": [
            {
              "name": "no",
              "value": "no"
            },
            {
              "name": "yes",
              "value": "yes"
            }
          ]
        },
        {
          "component": "text",
          "label": "tab text",
          "name": "tabItemText",
          "valueType": "string",
          "condition": {
            "===": [
              {
                "var": "secondLayerTab"
              },
              "no"
            ]
          }
        },
        {
          "component": "reference",
          "label": "icon assets (if show icon=yes)",
          "name": "tabItemIconAsset",
          "multi": false,
          "condition": {
            "===": [
              {
                "var": "secondLayerTab"
              },
              "no"
            ]
          }
        },
        {
          "component": "aem-content",
          "label": "fragment URL",
          "name": "tabItemFragmentUrl",
          "valueType": "string",
          "description": "Used when 2nd layer tab = no. Path to the ID12 container-2cols page.",
          "condition": {
            "===": [
              {
                "var": "secondLayerTab"
              },
              "no"
            ]
          }
        },
        {
          "component": "richtext",
          "label": "summary richtext (layout 4 + 2nd layer tab = yes)",
          "name": "summaryRichtext",
          "valueType": "string",
          "condition": {
            "and": [
              {
                "===": [
                  {
                    "var": "secondLayerTab"
                  },
                  "yes"
                ]
              }
            ]
          }
        },
        {
          "component": "container",
          "label": "sub items",
          "name": "subItems",
          "multi": true,
          "condition": {
            "and": [
              {
                "===": [
                  {
                    "var": "secondLayerTab"
                  },
                  "yes"
                ]
              }
            ]
          },
          "fields": [
            {
              "component": "text",
              "label": "tab text",
              "name": "subItemText",
              "valueType": "string"
            },
            {
              "component": "reference",
              "label": "icon asset (if show icon = yes)",
              "name": "subItemIconAsset",
              "multi": false
            },
            {
              "component": "aem-content",
              "label": "fragment URL",
              "name": "subItemFragmentUrl",
              "valueType": "string"
            }
          ]
        }
      ]
    }
  ],
  "filters": []
}
