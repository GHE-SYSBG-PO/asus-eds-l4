{
  "fields": [
    {
      "component": "tab",
      "label": "Basic",
      "name": "basicTab"
    },
    {
      "component": "select",
      "label": "style (layout variant)",
      "name": "styleLayout",
      "valueType": "string",
      "options": [
        {
          "name": "Variant 1 - Text On Left & Right",
          "value": "1"
        },
        {
          "name": "Variant 2 - Text On Left / Right Sides",
          "value": "2"
        },
        {
          "name": "Variant 3 - Text below",
          "value": "3"
        },
        {
          "name": "Variant 4 - Freeform",
          "value": "4"
        },
        {
          "name": "Variant 5 - Freeform-dialog box",
          "value": "5"
        }
      ]
    },
    {
      "component": "container",
      "label": "Asset",
      "name": "assetGroup",
      "collapsible": true,
      "fields": [
        {
          "component": "reference",
          "label": "asset (D)",
          "name": "assetDesktop",
          "multi": false
        },
        {
          "component": "text",
          "label": "img width(D)",
          "name": "assetDesktopImgWidth",
          "valueType": "string",
          "placeholder": "px"
        },
        {
          "component": "reference",
          "label": "asset (T)",
          "name": "assetTablet",
          "multi": false
        },
        {
          "component": "text",
          "label": "img width(T)",
          "name": "assetTabletImgWidth",
          "valueType": "string",
          "placeholder": "px"
        },
        {
          "component": "reference",
          "label": "asset (M)",
          "name": "assetMobile",
          "multi": false
        },
        {
          "component": "text",
          "label": "img width(M)",
          "name": "assetMobileImgWidth",
          "valueType": "string",
          "placeholder": "px"
        }
      ]
    },
    {
      "component": "container",
      "label": "Module Style",
      "name": "moduleStyleGroup",
      "collapsible": true,
      "fields": [
        {
          "component": "text",
          "label": "top padding(D)",
          "name": "paddingTopDesktop",
          "valueType": "string",
          "placeholder": "%|px|vh|vw|em|rem"
        },
        {
          "component": "text",
          "label": "top padding(T)",
          "name": "paddingTopTablet",
          "valueType": "string",
          "placeholder": "%|px"
        },
        {
          "component": "text",
          "label": "top padding(M)",
          "name": "paddingTopMobile",
          "valueType": "string",
          "placeholder": "%|px"
        },
        {
          "component": "text",
          "label": "bottom padding(D)",
          "name": "paddingBottomDesktop",
          "valueType": "string",
          "placeholder": "%|px"
        },
        {
          "component": "text",
          "label": "bottom padding(T)",
          "name": "paddingBottomTablet",
          "valueType": "string",
          "placeholder": "%|px"
        },
        {
          "component": "text",
          "label": "bottom padding(M)",
          "name": "paddingBottomMobile",
          "valueType": "string",
          "placeholder": "%|px"
        },
        {
          "component": "text",
          "label": "img width",
          "name": "imgWidth",
          "valueType": "string",
          "placeholder": "px"
        },
        {
          "component": "text",
          "label": "text width",
          "name": "textWidthPercent",
          "valueType": "string",
          "placeholder": "%",
          "condition": {
            "in": [
              {
                "var": "styleLayout"
              },
              [
                "1",
                "2"
              ]
            ]
          }
        },
        {
          "component": "text",
          "label": "text max width",
          "name": "textMaxWidth",
          "valueType": "string",
          "placeholder": "px",
          "condition": {
            "in": [
              {
                "var": "styleLayout"
              },
              [
                "1",
                "2"
              ]
            ]
          }
        }
      ]
    },
    {
      "...": "./_textItem1Fields.json#/fields"
    },
    {
      "...": "./_textItem2Fields.json#/fields"
    },
    {
      "...": "./_textItem3Fields.json#/fields"
    },
    {
      "...": "./_textItem4Fields.json#/fields"
    },
    {
      "...": "./_textItem5Fields.json#/fields"
    },
    {
      "...": "./_dialogBoxStyle.json#/fields"
    }
  ]
}