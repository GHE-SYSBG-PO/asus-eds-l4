{
  "fields": [
    {
      "component": "tab",
      "label": "Basic",
      "name": "basicTab"
    },
    {
      "component": "reference",
      "label": "asset (Desktop)",
      "name": "assetDesktop",
      "multi": false
    },
    {
      "component": "reference",
      "label": "asset (Tablet)",
      "name": "assetTablet",
      "multi": false
    },
    {
      "component": "reference",
      "label": "asset (Mobile)",
      "name": "assetMobile",
      "multi": false
    },
    {
      "component": "multifield",
      "label": "Text Items (Add multiple line info points here)",
      "name": "textItems",
      "field": {
        "component": "container",
        "name": "textItem",
        "label": "Item",
        "fields": [
          {
            "component": "select",
            "label": "side (left/ right)(DT)",
            "name": "side",
            "options": [
              {
                "name": "Left",
                "value": "left"
              },
              {
                "name": "Right",
                "value": "right"
              }
            ],
            "condition": {
              "===": [
                {
                  "var": "styleLayout"
                },
                "1"
              ]
            }
          },
          {
            "component": "select",
            "label": "layout style (left/ right)",
            "name": "layoutStyleSide",
            "options": [
              {
                "name": "Left",
                "value": "left"
              },
              {
                "name": "Right",
                "value": "right"
              }
            ],
            "condition": {
              "===": [
                {
                  "var": "styleLayout"
                },
                "2"
              ]
            }
          },
          {
            "component": "select",
            "label": "alignment (left / right)(DT)",
            "name": "alignment",
            "options": [
              {
                "name": "Left",
                "value": "left"
              },
              {
                "name": "Right",
                "value": "right"
              }
            ],
            "condition": {
              "in": [
                {
                  "var": "styleLayout"
                },
                [
                  "3",
                  "4",
                  "5"
                ]
              ]
            }
          },
          {
            "component": "text",
            "label": "text width (px)(DT)",
            "name": "textWidthPx",
            "valueType": "string",
            "condition": {
              "in": [
                {
                  "var": "styleLayout"
                },
                [
                  "3",
                  "4",
                  "5"
                ]
              ]
            }
          },
          {
            "component": "text",
            "label": "X value(left)(DT)",
            "name": "xValue",
            "valueType": "string",
            "condition": {
              "in": [
                {
                  "var": "styleLayout"
                },
                [
                  "3",
                  "4",
                  "5"
                ]
              ]
            }
          },
          {
            "component": "text",
            "label": "Y value(top)(DT)",
            "name": "yValue",
            "valueType": "string",
            "description": "文案太多可以是負值",
            "condition": {
              "in": [
                {
                  "var": "styleLayout"
                },
                [
                  "1",
                  "2",
                  "4",
                  "5"
                ]
              ]
            }
          },
          {
            "component": "richtext",
            "label": "title richtext",
            "name": "titleRichtext",
            "valueType": "string",
            "default": "<p>Item Title</p>"
          },
          {
            "component": "richtext",
            "label": "info richtext",
            "name": "infoRichtext",
            "valueType": "string",
            "default": "<p>Description text here...</p>"
          }
        ]
      }
    }
  ]
}