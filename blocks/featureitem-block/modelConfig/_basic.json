{
  "fields": [
    {
      "component": "tab",
      "label": "basic",
      "name": "basic"
    },
    {
      "component": "select",
      "label": "type",
      "name": "type",
      "valueType": "string",
      "options": [
        { "name": "text", "value": "text" },
        { "name": "icon", "value": "icon" }
      ]
    },
    {
      "component": "richtext",
      "label": "highlight text",
      "name": "highlightText",
      "valueType": "string",
      "condition": {
        "and": [
          { "===": [{ "var": "type" }, "text"] }
        ]
      }
    },
    {
      "component": "reference",
      "valueType": "string",
      "label": "icon source",
      "name": "iconSource",
